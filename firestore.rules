rules_version = '2';
  service cloud.firestore {
    match /databases/{database}/documents {

      match /listings/{listingId} {
        // Archived listings are only visible to their owner
        allow read: if resource == null
          || resource.data.get('archived', false) != true
          || (request.auth != null && request.auth.uid == resource.data.owner);
        allow write: if request.auth != null
          && (request.auth.uid == resource.data.owner
              || request.auth.uid in resource.data.editors);
        allow create: if request.auth != null;
      }

      match /users/{userId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == userId;
      }

      // ── Chats ──────────────────────────────────────────────────────────
      match /chats/{chatId} {
        // Allow reading non-existent docs (resource == null) so callers can
        // check whether a chat already exists before creating one.
        // For existing docs, only participants may read.
        allow read: if request.auth != null
          && (resource == null || request.auth.uid in resource.data.participants);

        // Anyone signed in can create a chat they're listed as a participant of
        allow create: if request.auth != null
          && request.auth.uid in request.resource.data.participants;

        // Participants can update (accept, block, unblock, decline, hide, update lastMessage etc.)
        allow update: if request.auth != null
          && request.auth.uid in resource.data.participants;

        match /messages/{msgId} {
          // Any authenticated user can read messages (participant check is on the
          // parent chat doc; the client already guards navigation)
          allow read: if request.auth != null;

          // Only the sender can write a message
          allow create: if request.auth != null
            && request.auth.uid == request.resource.data.senderId;
        }
      }

      // ── Share link aliases ──────────────────────────────────────────────
      match /shareLinks/{alias} {
        allow read: if true;
        allow create: if request.auth != null;
        // Click tracking must work for anonymous visitors
        allow update: if true;
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.createdBy;
      }

      // ── Notifications ───────────────────────────────────────────────────
      match /notifications/{userId}/items/{itemId} {
        allow read, update, delete: if request.auth != null
          && request.auth.uid == userId;
        allow create: if request.auth != null;
      }
    }
  }
