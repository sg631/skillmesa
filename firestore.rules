rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Listings ────────────────────────────────────────────────────────
    match /listings/{listingId} {
      // Archived listings are only visible to their owner or editors
      allow read: if resource == null
        || resource.data.get('archived', false) != true
        || (request.auth != null
            && (request.auth.uid == resource.data.owner
                || request.auth.uid in resource.data.get('editors', [])));
      // Owner or editors can write; anyone signed in can create
      allow write: if request.auth != null
        && (request.auth.uid == resource.data.owner
            || request.auth.uid in resource.data.get('editors', []));
      allow create: if request.auth != null;
      // Any authenticated user may update only the computed rating aggregate
      // (written client-side after a review is submitted or deleted)
      allow update: if request.auth != null
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'reviewCount']);

      // ── Reviews (one per user, owner cannot self-review) ────────────
      match /reviews/{reviewId} {
        allow read: if true;
        // Doc ID must equal the author's uid — enforces one-review-per-user
        // and makes it easy to find/overwrite an existing review.
        // Listing owner is not allowed to review their own listing.
        allow create: if request.auth != null
          && request.auth.uid == reviewId
          && get(/databases/$(database)/documents/listings/$(listingId)).data.owner
               != request.auth.uid;
        // Author can edit or delete their own review
        allow update: if request.auth != null && request.auth.uid == reviewId;
        allow delete: if request.auth != null && request.auth.uid == reviewId;
      }

      // ── Comments ─────────────────────────────────────────────────────
      match /comments/{commentId} {
        allow read: if true;
        allow create: if request.auth != null;
        // Only the comment author can delete their own comment
        allow delete: if request.auth != null
          && request.auth.uid == resource.data.authorId;
      }
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // ── Chats ────────────────────────────────────────────────────────────
    match /chats/{chatId} {
      // Allow reading non-existent docs so callers can check existence
      // before creating. For existing docs, only participants may read.
      allow read: if request.auth != null
        && (resource == null || request.auth.uid in resource.data.participants);

      allow create: if request.auth != null
        && request.auth.uid in request.resource.data.participants;

      // Participants can update (status, block, hide, unread counts, lastMessage…)
      allow update: if request.auth != null
        && request.auth.uid in resource.data.participants;

      match /messages/{msgId} {
        // Only participants of the parent chat can read messages
        allow read: if request.auth != null
          && request.auth.uid in
            get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        // Only the sender can create a message
        allow create: if request.auth != null
          && request.auth.uid == request.resource.data.senderId;
      }
    }

    // ── Share link aliases ───────────────────────────────────────────────
    match /shareLinks/{alias} {
      allow read: if true;
      allow create: if request.auth != null;
      // Click tracking: anyone (including anonymous) can increment the
      // three traffic fields. The owner can update anything.
      allow update: if
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['totalClicks', 'sources', 'lastClickAt'])
        || (request.auth != null
            && request.auth.uid == resource.data.createdBy);
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;
    }

    // ── Notifications ────────────────────────────────────────────────────
    match /notifications/{userId}/items/{itemId} {
      allow read, update, delete: if request.auth != null
        && request.auth.uid == userId;
      allow create: if request.auth != null;
    }

    // ── Groups ───────────────────────────────────────────────────────────
    match /groups/{groupId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy
        || exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
      );
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.createdBy;

      match /members/{memberId} {
        allow read: if request.auth != null;
        // Owner or admin can add/modify members
        allow write: if request.auth != null && (
          request.auth.uid == get(/databases/$(database)/documents/groups/$(groupId)).data.createdBy
          || (exists(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid))
              && get(/databases/$(database)/documents/groups/$(groupId)/members/$(request.auth.uid)).data.role in ['admin', 'owner'])
        );
        // Anyone can remove themselves
        allow delete: if request.auth != null && request.auth.uid == memberId;
      }
    }
  }
}
