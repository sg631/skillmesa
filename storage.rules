rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Listing assets (thumbnails + uploaded files) — anyone can read, any signed-in user can write
    match /listings/{listingId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    // Profile pictures — anyone can read, only the owner can write
    match /users/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
